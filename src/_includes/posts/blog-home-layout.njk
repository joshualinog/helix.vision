<div class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-4xl">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Blog</h1>
      <p class="mt-2 text-lg text-gray-600">Thoughts, ideas, and updates.</p>

      {% if pagedPosts and pagedPosts.length %}
        <div class="mt-16 space-y-20 lg:mt-20">
          {% for post in pagedPosts %}
            {% set postTags = post.data.tags or post.data.labels or [] %}
            {% set category = postTags[0] if postTags.length else 'Update' %}
            <article class="relative isolate flex flex-col gap-8 lg:flex-row">
              {% if post.data.mainImage %}
                <div class="relative aspect-video sm:aspect-2/1 lg:aspect-square lg:w-64 lg:shrink-0">
                  <img
                    src="{{ post.data.mainImage }}"
                    alt="{{ post.data.title }}"
                    class="absolute inset-0 size-full rounded-2xl bg-gray-50 object-cover"
                  />
                </div>
              {% endif %}

              <div>
                <div class="flex items-center gap-x-4 text-xs">
                  <time datetime="{{ post.data.date }}" class="text-gray-500">{{ post.data.date | date("LLL d, yyyy") }}</time>
                  <span class="relative z-10 rounded-full bg-gray-100 px-3 py-1.5 font-medium text-gray-600">{{ category }}</span>
                </div>

                <div class="group relative max-w-xl">
                  <h2 class="mt-3 text-2xl font-semibold text-gray-900 group-hover:text-gray-600">
                    <a href="{{ post.url }}">
                      <span class="absolute inset-0"></span>
                      {{ post.data.title }}
                    </a>
                  </h2>
                  <p class="mt-5 text-sm text-gray-600 line-clamp-3">{{ post.data.excerpt | striptags | truncate(220) }}</p>
                </div>

                <div class="mt-6 flex border-t border-gray-900/5 pt-6">
                  <div class="text-sm">
                    <p class="font-semibold text-gray-900">{{ post.data.author | default('helix.vision') }}</p>
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if pagination.pages.length > 1 %}
          <nav class="mt-16 border-t border-gray-200 pt-6" aria-label="Pagination">
            <div class="flex items-center justify-center gap-2">
              {% for pageHref in pagination.hrefs %}
                {% set isCurrentPage = loop.index0 == pagination.pageNumber %}
                <a
                  href="{{ pageHref }}"
                  aria-current="{{ 'page' if isCurrentPage else 'false' }}"
                  class="rounded-md px-3 py-2 text-sm font-semibold {% if isCurrentPage %}bg-gray-900 text-white{% else %}bg-white text-gray-700 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50{% endif %}"
                >{{ loop.index }}</a>
              {% endfor %}
            </div>
          </nav>
        {% endif %}
      {% else %}
        <p class="mt-8 text-gray-500">No posts yet.</p>
      {% endif %}
    </div>
  </div>
</div>
